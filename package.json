{
  "name": "voicenoter",
  "version": "0.1.0",
  "description": "Local desktop workspace for turning audio and video into Markdown notes.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "pnpm rebuild:electron && electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "pnpm rebuild:electron && electron-vite preview",
    "package": "pnpm rebuild:electron && pnpm build && electron-builder --linux --dir",
    "dist": "pnpm rebuild:electron && pnpm build && electron-builder --linux",
    "test": "pnpm rebuild:node && vitest run",
    "test:watch": "vitest",
    "rebuild:node": "pnpm rebuild better-sqlite3",
    "rebuild:electron": "electron-builder install-app-deps",
    "prepare:whisper": "node scripts/install-whisper.cpp.mjs",
    "postinstall": "pnpm rebuild:node"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@uiw/react-codemirror": "^4.25.10",
    "better-sqlite3": "^12.10.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "electron": "35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.voicenoter.app",
    "productName": "VoiceNoter",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor/whisper.cpp/build/bin",
        "to": "bin/whisper",
        "filter": [
          "whisper-cli*"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**",
      "vendor/whisper.cpp/build/bin/**"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}
